# ===== Model =====
LLM_API_KEY=your_api_key_here
MODEL=your_model_name
GRADE_MODEL=your_grade_model_name
FAST_MODEL=your_fast_model_name
AUX_MODEL=your_aux_model_name
BASE_URL=https://your-llm-endpoint/v1
# direct RAG 答案生成超时；主模型超时后切换 FAST_MODEL，再失败则返回片段摘要
DIRECT_RAG_ANSWER_MODEL=fast
DIRECT_RAG_ANSWER_TIMEOUT=45
DIRECT_RAG_REWRITE_TIMEOUT=20
DIRECT_RAG_VERIFY_TIMEOUT=8

# ===== 本地稠密向量（langchain_huggingface，默认 BAAI/bge-m3）=====
EMBEDDING_MODEL=BAAI/bge-m3
# auto: CUDA 可用时使用 GPU，否则回退 CPU；也可显式设置 cpu / cuda / cuda:0
EMBEDDING_DEVICE=auto
DENSE_EMBEDDING_DIM=1024

# ===== 多模态本地模型（CLIP）=====
MULTIMODAL_EMBEDDING_MODEL=openai/clip-vit-base-patch32
MULTIMODAL_EMBEDDING_DEVICE=auto
IMAGE_VECTOR_DIM=512

# ===== 图片 OCR fallback（可选）=====
# 需要额外安装 Tesseract OCR 程序；Windows 可把安装路径写到 TESSERACT_CMD。
OCR_ENABLED=true
OCR_LANG=chi_sim+eng
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_MAX_CHARS=800

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL=your_rerank_model
RERANK_BINDING_HOST=https://your-rerank-host
RERANK_API_KEY=your_rerank_api_key

# ===== 检索候选池 & Auto-merging =====
# Milvus 叶子层召回候选数：设 RETRIEVAL_CANDIDATE_K 时优先使用（且 >= top_k）
# 未设 K 时：candidate_k = max(top_k * RETRIEVAL_CANDIDATE_MULTIPLIER, top_k)
# RETRIEVAL_CANDIDATE_K=15
RETRIEVAL_CANDIDATE_MULTIPLIER=3
FINAL_TOP_K=3
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
LEAF_RETRIEVE_LEVEL=3
# 默认 UBG 融合；如需降级到传统 RRF，可设置为 rrf
RETRIEVAL_FUSION_METHOD=ubg
# 可选：训练好的 UBG 权重；不配置时使用启发式 fallback
# UBG_MODEL_PATH=data/ubg_fusion_weights.pt
UBG_DEVICE=auto
UBG_TRAIN_DEVICE=auto
# 精排后进入 Agent 的最低分（默认 0，上线后按数据标定）
RERANK_MIN_SCORE=0.0

# ===== 图片检索阈值 =====
IMAGE_RETRIEVAL_MIN_SCORE=0.18
IMAGE_RETRIEVAL_FALLBACK_MIN_SCORE=0.10

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection
# 单次 RPC 超时（秒）；连接按请求创建，不长期占用 gRPC channel
MILVUS_TIMEOUT=30

# ===== Database / Cache =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/langchain_app
REDIS_URL=redis://127.0.0.1:6379/0

# ===== Auth =====
# Public deployments must replace both values below.
# JWT_SECRET_KEY should be a long random string; ADMIN_INVITE_CODE controls admin registration.
JWT_SECRET_KEY=replace-with-strong-random-secret
ADMIN_INVITE_CODE=replace-with-private-admin-invite-code
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# ===== BM25 稀疏统计持久化（默认 data/bm25_state.json，可改路径）=====
# BM25_STATE_PATH=/path/to/bm25_state.json

# ===== Tools（可选）=====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your_amap_api_key
